{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "ESNext",
                            "lib":  [
                                        "ES2020",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "moduleResolution":  "node",
                            "allowJs":  true,
                            "checkJs":  true,
                            "jsx":  "preserve",
                            "strict":  false,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "static/js/*"
                                                  ],
                                          "@core/*":  [
                                                          "static/js/core/*"
                                                      ],
                                          "@fx":  [
                                                      "static/js/core/framework/index.js"
                                                  ]
                                      }
                        },
    "include":  [
                    "static/js/**/*.ts",
                    "static/js/**/*.js",
                    "static/js/**/*.vue"
                ],
    "exclude":  [
                    "node_modules",
                    "**/node_modules/*"
                ]
}
